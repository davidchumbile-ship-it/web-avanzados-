<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Social Media - Posts</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
</head>

<body class="grey lighten-4">
    <nav>
        <div class="nav-wrapper teal">
            <a href="#!" class="brand-logo center">Social Media</a>
        </div>
    </nav>
    <div class="container" style="margin-top: 30px;">
        <div class="row">
            <div class="col s12 center-align">
                <a href="/posts/create" class="btn-large teal waves-effect waves-light">
                    <i class="material-icons left">add</i>Nuevo Post
                </a>
            </div>
        </div>
        <div class="row">
            <% if (posts.length===0) { %>
                <div class="col s12 center-align">
                    <p class="flow-text">No hay posts aún. ¡Crea el primero!</p>
                </div>
                <% } %>
                    <% posts.forEach(post=> { %>
                        <div class="col s12 m6 l4">
                            <div class="card">
                                <div class="card-image">
                                    <img src="<%= post.imageUrl || 'https://media.istockphoto.com/id/627795510/photo/example.jpg?s=612x612&w=0&k=20&c=lpUf5rjPVd6Kl_M6heqC8sUncR4FLmtsRzeYdTr5X_I=' %>"
                                        alt="Imagen del post">
                                </div>
                                <div class="card-content">
                                    <span class="card-title">
                                        <%= post.title %>
                                    </span>
                                    <p>
                                        <%= post.content %>
                                    </p>
                                    <% if (post.hashtags && post.hashtags.length> 0) { %>
                                        <p style="margin-top: 10px;">
                                            <% post.hashtags.forEach(tag=> { %>
                                                <span class="chip">#<%= tag %></span>
                                                <% }) %>
                                        </p>
                                        <% } %>
                                </div>
                                <div class="card-action">
                                    <span><strong>Autor:</strong>
                                        <%= post.user ? post.user.name + ' ' + post.user.lastName : 'Desconocido' %>
                                    </span>
                                    <div class="right">
                                        <a href="/posts/edit/<%= post._id %>" class="btn-flat">
                                            <i class="material-icons teal-text">edit</i>
                                        </a>
                                        <form action="/posts/delete/<%= post._id %>" method="POST"
                                            style="display:inline;">
                                            <button type="submit" class="btn-flat"
                                                onclick="return confirm('¿Eliminar este post?')">
                                                <i class="material-icons red-text">delete</i>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <% }) %>
        </div>
    </div>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
</body>

</html>