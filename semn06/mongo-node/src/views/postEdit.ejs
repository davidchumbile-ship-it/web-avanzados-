<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Post</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background: #0f0f0f;
            color: #fff;
            min-height: 100vh;
        }

        nav {
            background: #161616;
            border-bottom: 1px solid #222;
            padding: 18px 40px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .nav-logo {
            font-size: 1.4rem;
            font-weight: 800;
            background: linear-gradient(135deg, #00c9ff, #92fe9d);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .btn-back {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: #1a1a1a;
            color: #888;
            font-size: 0.9rem;
            padding: 10px 20px;
            border-radius: 50px;
            text-decoration: none;
            border: 1px solid #2a2a2a;
            transition: color 0.2s, border-color 0.2s;
        }

        .btn-back:hover {
            color: #fff;
            border-color: #444;
        }

        .container {
            max-width: 680px;
            margin: 50px auto;
            padding: 0 24px;
        }

        .page-title {
            font-size: 1.8rem;
            font-weight: 700;
            margin-bottom: 30px;
        }

        .form-card {
            background: #1a1a1a;
            border: 1px solid #2a2a2a;
            border-radius: 20px;
            padding: 36px;
        }

        .form-group {
            margin-bottom: 24px;
        }

        label {
            display: block;
            font-size: 0.85rem;
            font-weight: 600;
            color: #888;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        input,
        textarea {
            width: 100%;
            background: #111;
            border: 1px solid #2a2a2a;
            border-radius: 12px;
            color: #fff;
            font-size: 0.95rem;
            padding: 14px 16px;
            outline: none;
            font-family: 'Segoe UI', sans-serif;
            transition: border-color 0.2s;
        }

        input:focus,
        textarea:focus {
            border-color: #00c9ff;
        }

        textarea {
            resize: vertical;
            min-height: 120px;
        }

        .btn-submit {
            width: 100%;
            padding: 16px;
            background: linear-gradient(135deg, #00c9ff, #92fe9d);
            color: #0f0f0f;
            font-weight: 700;
            font-size: 1rem;
            border: none;
            border-radius: 12px;
            cursor: pointer;
            transition: opacity 0.2s, transform 0.2s;
            margin-top: 8px;
        }

        .btn-submit:hover {
            opacity: 0.9;
            transform: translateY(-2px);
        }

        .badge-edit {
            display: inline-block;
            background: #1e3a3a;
            color: #00c9ff;
            font-size: 0.75rem;
            font-weight: 600;
            padding: 4px 12px;
            border-radius: 50px;
            margin-bottom: 16px;
            border: 1px solid #00c9ff33;
        }
    </style>
</head>

<body>
    <nav>
        <div class="nav-logo">● SocialMedia</div>
        <a href="/posts" class="btn-back">← Volver</a>
    </nav>
    <div class="container">
        <h1 class="page-title">Editar Post</h1>
        <div class="form-card">
            <span class="badge-edit">✏️ Modo edición</span>
            <form action="/posts/edit/<%= post._id %>" method="POST">
                <div class="form-group">
                    <label>Título</label>
                    <input type="text" name="title" value="<%= post.title %>" required>
                </div>
                <div class="form-group">
                    <label>Contenido</label>
                    <textarea name="content" required><%= post.content %></textarea>
                </div>
                <div class="form-group">
                    <label>Hashtags</label>
                    <input type="text" name="hashtags" value="<%= post.hashtags ? post.hashtags.join(', ') : '' %>">
                </div>
                <div class="form-group">
                    <label>URL de imagen</label>
                    <input type="text" name="imageUrl" value="<%= post.imageUrl || '' %>">
                </div>
                <button type="submit" class="btn-submit">Guardar Cambios</button>
            </form>
        </div>
    </div>
</body>

</html>